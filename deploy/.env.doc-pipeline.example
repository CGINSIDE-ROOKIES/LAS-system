# MidM LLM
MIDM_LLM_URL=

# OpenAI (GPT-5 Nano)
OPENAI_API_KEY=

# Google (Gemini Flash Lite)
GOOGLE_API_KEY=

# Embedding model
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# Backend: "cpu" (sentence-transformers) or "openvino"
EMBEDDING_BACKEND=cpu
# Device for OpenVINO backend: "CPU" or "GPU" (ignored when backend=cpu)
# EMBEDDING_DEVICE=CPU

# Qdrant (for doc-processor search)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=law_article
