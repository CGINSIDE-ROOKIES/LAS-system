# -----------------------------------------------------------------------------
# Frontend (apps/frontend, deploy service: frontend)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=
BACKEND_INTERNAL_URL=http://backend-api:8000
ALLOWED_FRAME_ORIGINS=

# -----------------------------------------------------------------------------
# Backend API core (apps/backend/api, deploy service: backend-api)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://cg-rookies:cg-inside@mvrhbtidjg4mbasvnrw4imbm:5432/las
DOCUMENT_REVIEW_STORAGE_DIR=/app/storage/document_reviews
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Backend API / RAG answer generation LLM (apps/backend/rag via backend-api)
# LLM_PROVIDER options: gemini | openai_compat
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai_compat
LLM_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
LLM_URL=http://spark.cg-rookies.net:8000/v1/chat/completions
LLM_BASE_URL=
LLM_API_KEY=
LLM_TIMEOUT=120
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2
LAW_SLOT_SCORE_THRESHOLD=0.55

# -----------------------------------------------------------------------------
# Backend API / RAG query parser LLM (apps/backend/rag)
# QUERY_PARSER_LLM_STRICT options: false | true
# -----------------------------------------------------------------------------
QUERY_PARSER_LLM_PROVIDER=openai_compat
QUERY_PARSER_LLM_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
QUERY_PARSER_LLM_URL=http://spark.cg-rookies.net:8000/v1/chat/completions
QUERY_PARSER_LLM_API_KEY=
QUERY_PARSER_LLM_TIMEOUT=10
QUERY_PARSER_LLM_STRICT=false

# -----------------------------------------------------------------------------
# Backend API / graph planner LLM (apps/backend/rag graph routes)
# GRAPH_QUERY_MODE options: template | llm_free | llm_free_with_template_fallback
# -----------------------------------------------------------------------------
GRAPH_QUERY_MODE=llm_free
GRAPH_LLM_PROVIDER=openai_compat
GRAPH_LLM_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
GRAPH_LLM_URL=http://spark.cg-rookies.net:8000/v1/chat/completions
GRAPH_LLM_API_KEY=
GRAPH_LLM_TIMEOUT=15
GRAPH_LLM_MAX_TOKENS=2048
GRAPH_LLM_TEMPERATURE=0

# -----------------------------------------------------------------------------
# Backend API / doc_processor LLM (apps/backend/doc_processor via backend-api)
# DOC_PROCESSOR_LLM_PROVIDER options: openai | openai_compat | gemini
# DOC_PROCESSOR_LLM_STRUCTURED_METHOD options: json_mode | json_schema
# -----------------------------------------------------------------------------
DOC_PROCESSOR_LLM_PROVIDER=openai_compat
DOC_PROCESSOR_LLM_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
DOC_PROCESSOR_LLM_URL=http://spark.cg-rookies.net:8000/v1/chat/completions
DOC_PROCESSOR_LLM_BASE_URL=
DOC_PROCESSOR_LLM_API_KEY=
DOC_PROCESSOR_LLM_TIMEOUT_SECONDS=
DOC_PROCESSOR_LLM_STRUCTURED_METHOD=json_mode

# -----------------------------------------------------------------------------
# Shared embeddings (backend-api/RAG, doc_processor, legal-pipeline, law-updater)
# EMBEDDING_PROVIDER options: openai_compat
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai_compat
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DIMENSIONS=1024
EMBEDDING_MAX_INPUT_TOKENS=8192
EMBEDDING_MAX_BATCH_TOKENS=300000
EMBEDDING_MAX_RETRIES=5
EMBEDDING_RETRY_BASE_DELAY_SEC=1.0

# -----------------------------------------------------------------------------
# Shared retrieval stores (backend-api/RAG, doc_processor, law-updater upload)
# QDRANT_COLLECTIONS entries used by this stack: law_article | legal_case | legal_relation
# OPENSEARCH_INDEX entries used by this stack: law_article | legal_case | legal_relation
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant-qhepejgiqexcpwgibixh2rho:6333
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
QDRANT_API_KEY=
QDRANT_VECTOR_NAME_MAP=law_article=body
OPENSEARCH_URL=http://opensearch-qq82lzpyb7t6qcmk6e0lkk88:9200
OPENSEARCH_INDEX=law_article,legal_case,legal_relation
OPENSEARCH_API_KEY=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_SEARCH_TEXT_FIELD=search_text

# -----------------------------------------------------------------------------
