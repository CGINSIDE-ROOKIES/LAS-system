# MidM LLM
MIDM_LLM_URL=

# OpenAI
OPENAI_API_KEY=

# Google / Gemini
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Embedding
# provider: sentence_transformers (기본값) | openai
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_BACKEND=cpu
EMBEDDING_DEVICE=CPU
# OpenAI 임베딩 사용 시
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_BASE_URL=https://api.openai.com/v1

# Vector DB - if running in same Compose stack, prefer service name over localhost
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=law_article
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
# QDRANT_API_KEY=
# QDRANT_VECTOR_NAME_MAP=law_article=body

# OpenSearch - if running in same Compose stack, prefer service name over localhost
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=las_legal_docs
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=

# LLM provider
LLM_PROVIDER=gemini

# OpenAI-compatible LLM
# LLM_CHAT_COMPLETIONS_URL=
# LLM_MODEL=
# LLM_API_KEY=

# LLM generation
LLM_MAX_TOKENS=4096

# PostgreSQL - if running in same Compose stack, prefer service name over localhost
DATABASE_URL=postgresql://user:password@postgres:5432/db

# Frontend -> Backend
# Public backend URL used directly by the browser. Leave empty to use frontend proxying.
NEXT_PUBLIC_API_URL=
BACKEND_INTERNAL_URL=http://backend-api:8000

ALLOWED_FRAME_ORIGINS=