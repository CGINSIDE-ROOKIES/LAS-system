# MidM LLM
MIDM_LLM_URL=

# OpenAI
OPENAI_API_KEY=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Embedding
# API only
EMBEDDING_MODEL=text-embedding-3-large
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_DIMENSIONS=1024

# Law updater job
LAW_OC=
LAW_API_BASE_URL=https://www.law.go.kr/DRF
LAW_UPDATER_EMBEDDING_MODEL=text-embedding-3-large
LAW_UPDATER_OPENAI_BASE_URL=https://api.openai.com/v1
LAW_UPDATER_OPENAI_EMBEDDING_DIMENSIONS=1024
LAW_UPDATER_OPENAI_MAX_INPUT_TOKENS=8192
LAW_UPDATER_OPENAI_MAX_BATCH_TOKENS=300000
LAW_UPDATER_OPENAI_MAX_RETRIES=5
LAW_UPDATER_OPENAI_RETRY_BASE_DELAY_SEC=1.0

# Vector DB - if running in same Compose stack, prefer service name over localhost
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
QDRANT_API_KEY=
QDRANT_VECTOR_NAME_MAP=law_article=body

# OpenSearch - if running in same Compose stack, prefer service name over localhost
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=law_article,legal_case,legal_relation
OPENSEARCH_API_KEY=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# neo4j - if running in same Compose stack, prefer service name over localhost
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# NL2Cypher (template | llm_free | llm_free_with_template_fallback)
GRAPH_QUERY_MODE=llm_free

# Query Parser (법령명/조문번호 추출 LLM)
# 생략 시 GEMINI_MODEL → gemini-2.0-flash-lite 순으로 fallback
QUERY_PARSER_MODEL=gemini-2.5-flash-lite
QUERY_PARSER_TIMEOUT=10
QUERY_PARSER_STRICT=false

# LLM provider
LLM_PROVIDER=gemini

# OpenAI-compatible LLM
# LLM_CHAT_COMPLETIONS_URL=
# LLM_MODEL=
# LLM_API_KEY=

# LLM generation
LLM_MAX_TOKENS=2048

# PostgreSQL - if running in same Compose stack, prefer service name over localhost
DATABASE_URL=postgres://user@pw:5432/las

# Frontend -> Backend
# Public backend URL used directly by the browser. Leave empty to use frontend proxying.
NEXT_PUBLIC_API_URL=
BACKEND_INTERNAL_URL=http://backend-api:8000
ALLOWED_FRAME_ORIGINS=

LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
