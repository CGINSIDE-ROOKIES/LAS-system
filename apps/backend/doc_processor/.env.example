# Auto-loaded by `doc_processor.llm.factory.get_chat_model()` for local runs.
# Shell-exported variables still take precedence over these values.
#
# Generic fallback (used by any profile if profile-specific value is missing)
DOC_PROCESSOR_LLM_PROVIDER=openai_compat
DOC_PROCESSOR_LLM_MODEL=gpt-4.1-mini
DOC_PROCESSOR_LLM_BASE_URL=
DOC_PROCESSOR_LLM_API_KEY=

# Gemini example:
# DOC_PROCESSOR_LLM_PROVIDER=gemini
# DOC_PROCESSOR_LLM_MODEL=gemini-2.5-flash-lite
# DOC_PROCESSOR_LLM_API_KEY=...
# GOOGLE_API_KEY=...

# Optional profile-specific override (example: profile="default")
# DOC_PROCESSOR_LLM_DEFAULT_PROVIDER=openai_compat
# DOC_PROCESSOR_LLM_DEFAULT_MODEL=gpt-4.1-mini
# DOC_PROCESSOR_LLM_DEFAULT_BASE_URL=
# DOC_PROCESSOR_LLM_DEFAULT_API_KEY=

# Optional profile-specific override (example: profile="prod")
# DOC_PROCESSOR_LLM_PROD_PROVIDER=openai
# DOC_PROCESSOR_LLM_PROD_MODEL=gpt-4.1
# DOC_PROCESSOR_LLM_PROD_BASE_URL=
# DOC_PROCESSOR_LLM_PROD_API_KEY=

# Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
