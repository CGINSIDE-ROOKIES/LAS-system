# Auto-loaded by `doc_processor.llm.factory.get_chat_model()` for local runs.
# Shell-exported variables still take precedence over these values.
#
# Generic fallback: used by any profile if a profile-specific value is missing.
DOC_PROCESSOR_LLM_PROVIDER=openai_compat
DOC_PROCESSOR_LLM_MODEL=gpt-4.1-mini
DOC_PROCESSOR_LLM_BASE_URL=
DOC_PROCESSOR_LLM_API_KEY=

# Gemini example:
# DOC_PROCESSOR_LLM_PROVIDER=gemini
# DOC_PROCESSOR_LLM_MODEL=gemini-2.5-flash
# DOC_PROCESSOR_LLM_API_KEY=
# GOOGLE_API_KEY=

###############################################################################

# Structured output method:
# - json_mode: broadest compatibility
# - json_schema: stricter schema enforcement on compatible providers
DOC_PROCESSOR_LLM_STRUCTURED_METHOD=json_mode

# Phase-1 profile examples used by the current graph:
#   relevance_llm_profile="relevance"
#   boundary_llm_profile="boundary"
#   label_llm_profile="label"
#
# Example: use Gemini Flash only for ambiguous relevance checks
# DOC_PROCESSOR_LLM_RELEVANCE_PROVIDER=gemini
# DOC_PROCESSOR_LLM_RELEVANCE_MODEL=gemini-2.5-flash
# DOC_PROCESSOR_LLM_RELEVANCE_API_KEY=
# DOC_PROCESSOR_LLM_RELEVANCE_STRUCTURED_METHOD=json_mode
#
# Example: use a larger OpenAI-compatible model for boundary review
# DOC_PROCESSOR_LLM_BOUNDARY_PROVIDER=openai_compat
# DOC_PROCESSOR_LLM_BOUNDARY_MODEL=gpt-4.1
# DOC_PROCESSOR_LLM_BOUNDARY_BASE_URL=
# DOC_PROCESSOR_LLM_BOUNDARY_API_KEY=
# DOC_PROCESSOR_LLM_BOUNDARY_STRUCTURED_METHOD=json_schema
#
# Example: use Gemini Flash for ambiguous paragraph labeling
# DOC_PROCESSOR_LLM_LABEL_PROVIDER=gemini
# DOC_PROCESSOR_LLM_LABEL_MODEL=gemini-2.5-flash
# DOC_PROCESSOR_LLM_LABEL_API_KEY=
# DOC_PROCESSOR_LLM_LABEL_STRUCTURED_METHOD=json_mode
#
# Additional profile examples
# DOC_PROCESSOR_LLM_DEFAULT_PROVIDER=openai_compat
# DOC_PROCESSOR_LLM_DEFAULT_MODEL=gpt-4.1-mini
# DOC_PROCESSOR_LLM_DEFAULT_BASE_URL=
# DOC_PROCESSOR_LLM_DEFAULT_API_KEY=
#
# DOC_PROCESSOR_LLM_PROD_PROVIDER=openai
# DOC_PROCESSOR_LLM_PROD_MODEL=gpt-4.1
# DOC_PROCESSOR_LLM_PROD_BASE_URL=
# DOC_PROCESSOR_LLM_PROD_API_KEY=

# Langfuse observability
#
# `LANGFUSE_BASE_URL` is preferred. `LANGFUSE_HOST` is still accepted by the SDK.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_HOST=https://cloud.langfuse.com
#
# Optional Langfuse SDK settings
# LANGFUSE_TRACING_ENVIRONMENT=local
# LANGFUSE_RELEASE=
# LANGFUSE_TRACING_ENABLED=true
# LANGFUSE_SAMPLE_RATE=1.0
