{
  "legal_appendix_raw.jsonl": {
    "description": "본문 코퍼스와 분리된 별표 원천 JSONL. 별지/서식은 제외하고, API text·파일 메타데이터·분류 결과·후속 처리 정책을 함께 보관하며, asset pipeline 실행 시 best_text_source 및 구조화 표 추출 요약도 함께 가진다.",
    "record_level": "one_record_per_appendix_unit",
    "fields": [
      "id",
      "doc_type",
      "source_group",
      "law_name",
      "law_id",
      "mst",
      "ef_yd",
      "kind_name",
      "ministry_name",
