  },
  "legal_appendix_clean.jsonl": {
    "description": "기본 serving 후보인 appendix_document 전용 cleaned/chunked JSONL. 텍스트형 별표를 우선 담으며, API markdown이 있으면 api_markdown을, 없으면 api_text를 사용한다. asset pipeline이 실행되면 필요 시 pdf_text가 fallback으로 사용된다.",
    "record_level": "one_record_per_chunk",
    "fields": [
