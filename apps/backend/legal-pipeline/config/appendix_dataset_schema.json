      "appendix_title",
      "api_text_raw",
      "api_text",
      "api_text_line_count",
      "api_table_count",
      "api_table_markdown_text",
      "api_document_markdown",
      "table_signal_count",
      "form_signal_count",
      "has_substantive_text",
      "has_table_markup",
      "is_default_serving_candidate",
      "download_assets",
      "processing_policy",
      "best_text_source",
      "best_text_reason",
      "asset_text_available",
