  "legal_appendix_table.jsonl": {
    "description": "별표 중 table_appendix 전용 structured JSONL. API box-text markdown을 우선 사용하고, 필요 시 PDF 구조화 표를 fallback으로 사용한다.",
    "record_level": "one_record_per_table_or_chunk",
