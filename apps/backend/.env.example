# Qdrant
QDRANT_URL=http://localhost:6333  # 변경 필요
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
QDRANT_VECTOR_NAME_MAP=law_article=body
# QDRANT_API_KEY=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200  # 변경 필요
OPENSEARCH_INDEX=law_article,legal_case,legal_relation
# OPENSEARCH_API_KEY=
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=

# Query Embedding
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_DIMENSIONS=1024
# OPENAI_BASE_URL=https://api.openai.com/v1

# LLM provider (openai_compat | gemini)
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI-compat (LLM_PROVIDER=openai_compat 시)
# LLM_MODEL=gpt-4o-mini
# LLM_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=

# Query Parser — 생략 시 GEMINI_MODEL 값 사용, 둘 다 없으면 gemini-2.0-flash-lite
QUERY_PARSER_MODEL=gpt-4o-mini
QUERY_PARSER_TIMEOUT=10
QUERY_PARSER_STRICT=false

# LLM generation
LLM_MAX_TOKENS=2048

# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse.cg-rookies.yeongmin.net
# LANGFUSE_HOST=https://cloud.langfuse.com

# Neo4j
NEO4J_URI=bolt://neo4j.cg-rookies.yeongmin.net:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# NL2Cypher 방식 선택 (template | llm_free | llm_free_with_template_fallback)
# template: 슬롯 추출 + 고정 템플릿 (방식 A, 기본)
# llm_free: LLM 자유 Cypher 생성 (방식 B, 권장)
# llm_free_with_template_fallback: 방식 B 실패 시 방식 A 자동 fallback
GRAPH_QUERY_MODE=llm_free

# PostgreSQL (Q&A history)
DATABASE_URL=postgresql://las:las@localhost:5432/las