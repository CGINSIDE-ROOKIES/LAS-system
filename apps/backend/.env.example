# -----------------------------------------------------------------------------
# Backend API core (apps/backend/api)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://las:las@localhost:5432/las
DOCUMENT_REVIEW_STORAGE_DIR=
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# RAG answer generation LLM (apps/backend/rag)
# Provider options: gemini | openai_compat
# For openai_compat, LLM_URL is the full /v1/chat/completions endpoint.
# LLM_BASE_URL may be used instead when you want the app to append /chat/completions.
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash-lite
LLM_URL=
LLM_BASE_URL=
LLM_API_KEY=
LLM_TIMEOUT=120
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2
LAW_SLOT_SCORE_THRESHOLD=0.55

# -----------------------------------------------------------------------------
# RAG query parser LLM (apps/backend/rag)
# QUERY_PARSER_LLM_STRICT options: false | true
# -----------------------------------------------------------------------------
QUERY_PARSER_LLM_PROVIDER=gemini
QUERY_PARSER_LLM_MODEL=gemini-2.5-flash-lite
QUERY_PARSER_LLM_URL=
QUERY_PARSER_LLM_API_KEY=
QUERY_PARSER_LLM_TIMEOUT=10
QUERY_PARSER_LLM_STRICT=false

# -----------------------------------------------------------------------------
# RAG graph planner LLM (apps/backend/rag graph routes)
# GRAPH_QUERY_MODE options: template | llm_free | llm_free_with_template_fallback
# -----------------------------------------------------------------------------
GRAPH_QUERY_MODE=llm_free
GRAPH_LLM_PROVIDER=gemini
GRAPH_LLM_MODEL=gemini-2.5-flash-lite
GRAPH_LLM_URL=
GRAPH_LLM_API_KEY=
GRAPH_LLM_TIMEOUT=15
GRAPH_LLM_MAX_TOKENS=2048
GRAPH_LLM_TEMPERATURE=0

# -----------------------------------------------------------------------------
# Document processor LLM (apps/backend/doc_processor)
# DOC_PROCESSOR_LLM_PROVIDER options: openai | openai_compat | gemini
# DOC_PROCESSOR_LLM_STRUCTURED_METHOD options: json_mode | json_schema
# -----------------------------------------------------------------------------
DOC_PROCESSOR_LLM_PROVIDER=openai_compat
DOC_PROCESSOR_LLM_MODEL=gpt-4.1-mini
DOC_PROCESSOR_LLM_URL=
DOC_PROCESSOR_LLM_BASE_URL=
DOC_PROCESSOR_LLM_API_KEY=
DOC_PROCESSOR_LLM_TIMEOUT_SECONDS=
DOC_PROCESSOR_LLM_STRUCTURED_METHOD=json_mode

DOC_PROCESSOR_LLM_RELEVANCE_PROVIDER=
DOC_PROCESSOR_LLM_RELEVANCE_MODEL=
DOC_PROCESSOR_LLM_RELEVANCE_URL=
DOC_PROCESSOR_LLM_RELEVANCE_BASE_URL=
DOC_PROCESSOR_LLM_RELEVANCE_API_KEY=
DOC_PROCESSOR_LLM_RELEVANCE_TIMEOUT_SECONDS=
DOC_PROCESSOR_LLM_RELEVANCE_STRUCTURED_METHOD=

DOC_PROCESSOR_LLM_BOUNDARY_PROVIDER=
DOC_PROCESSOR_LLM_BOUNDARY_MODEL=
DOC_PROCESSOR_LLM_BOUNDARY_URL=
DOC_PROCESSOR_LLM_BOUNDARY_BASE_URL=
DOC_PROCESSOR_LLM_BOUNDARY_API_KEY=
DOC_PROCESSOR_LLM_BOUNDARY_TIMEOUT_SECONDS=
DOC_PROCESSOR_LLM_BOUNDARY_STRUCTURED_METHOD=

DOC_PROCESSOR_LLM_LABEL_PROVIDER=
DOC_PROCESSOR_LLM_LABEL_MODEL=
DOC_PROCESSOR_LLM_LABEL_URL=
DOC_PROCESSOR_LLM_LABEL_BASE_URL=
DOC_PROCESSOR_LLM_LABEL_API_KEY=
DOC_PROCESSOR_LLM_LABEL_TIMEOUT_SECONDS=
DOC_PROCESSOR_LLM_LABEL_STRUCTURED_METHOD=

DOC_PROCESSOR_LLM_DEFAULT_PROVIDER=
DOC_PROCESSOR_LLM_DEFAULT_MODEL=
DOC_PROCESSOR_LLM_DEFAULT_URL=
DOC_PROCESSOR_LLM_DEFAULT_BASE_URL=
DOC_PROCESSOR_LLM_DEFAULT_API_KEY=
DOC_PROCESSOR_LLM_DEFAULT_TIMEOUT_SECONDS=
DOC_PROCESSOR_LLM_DEFAULT_STRUCTURED_METHOD=

DOC_PROCESSOR_LLM_PROD_PROVIDER=
DOC_PROCESSOR_LLM_PROD_MODEL=
DOC_PROCESSOR_LLM_PROD_URL=
DOC_PROCESSOR_LLM_PROD_BASE_URL=
DOC_PROCESSOR_LLM_PROD_API_KEY=
DOC_PROCESSOR_LLM_PROD_TIMEOUT_SECONDS=
DOC_PROCESSOR_LLM_PROD_STRUCTURED_METHOD=

# -----------------------------------------------------------------------------
# Shared embeddings (RAG, doc_processor, legal-pipeline, law-updater)
# EMBEDDING_PROVIDER options: openai_compat
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai_compat
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_DIMENSIONS=1024
EMBEDDING_MAX_INPUT_TOKENS=8192
EMBEDDING_MAX_BATCH_TOKENS=300000
EMBEDDING_MAX_RETRIES=5
EMBEDDING_RETRY_BASE_DELAY_SEC=1.0

# -----------------------------------------------------------------------------
# Qdrant (RAG retrieval and upload scripts)
# QDRANT_COLLECTIONS entries used by this stack: law_article | legal_case | legal_relation
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
QDRANT_API_KEY=
QDRANT_VECTOR_NAME_MAP=law_article=body
QDRANT_TIMEOUT_SEC=30
QDRANT_HANDOFF_DIR=
QDRANT_EMB_DIR=

# -----------------------------------------------------------------------------
# OpenSearch (RAG retrieval and upload scripts)
# OPENSEARCH_INDEX entries used by this stack: law_article | legal_case | legal_relation
# -----------------------------------------------------------------------------
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=law_article,legal_case,legal_relation
OPENSEARCH_API_KEY=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_SEARCH_TEXT_FIELD=search_text
OPENSEARCH_TIMEOUT_SEC=60
OPENSEARCH_ENABLE_NORI_POS_FILTER=
OPENSEARCH_BULK_DIR=
OPENSEARCH_INCREMENTAL_DIR=
OPENSEARCH_INDEX_LAW_ARTICLE=law_article
OPENSEARCH_INDEX_LEGAL_CASE=legal_case
OPENSEARCH_INDEX_LEGAL_RELATION=legal_relation

# -----------------------------------------------------------------------------
# Neo4j (RAG graph routes and legal-pipeline graph seed)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HEAP_INITIAL_SIZE=512m
NEO4J_HEAP_MAX_SIZE=2G
NEO4J_PAGECACHE_SIZE=1G

# -----------------------------------------------------------------------------
# Law collection and updater (apps/backend/legal-pipeline, apps/backend/law-updater)
# -----------------------------------------------------------------------------
LAW_OC=
LAW_API_BASE_URL=https://www.law.go.kr/DRF
ENABLE_APPENDIX_ASSET_PIPELINE=
APPENDIX_DOWNLOAD_ASSETS=
APPENDIX_OVERWRITE_ASSETS=
APPENDIX_DOWNLOAD_TIMEOUT_SEC=60
APPENDIX_DOWNLOAD_BASE_URL=https://www.law.go.kr

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_TIMEOUT=30
LANGFUSE_FLUSH_AT=64
LANGFUSE_FLUSH_INTERVAL=1
LANGFUSE_DEBUG=
LANGFUSE_TRACING_ENVIRONMENT=local
LANGFUSE_RELEASE=
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_SAMPLE_RATE=1.0
