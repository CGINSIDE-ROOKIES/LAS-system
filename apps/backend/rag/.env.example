# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
# QDRANT_API_KEY=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=law_article,legal_case,legal_relation
# OPENSEARCH_API_KEY=
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=

# Query embedding model (768 dim)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Index input glob (for index_embedded_jsonl.py)
INDEX_INPUT_GLOB=data/dropbox/*.embedded.jsonl

# LLM provider (openai_compat | gemini)
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# LLM generation
LLM_MAX_TOKENS=4096
