# Qdrant
QDRANT_URL=http://localhost:6333  # 변경 필요
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
QDRANT_VECTOR_NAME_MAP=law_article=body
# QDRANT_API_KEY=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200  # 변경 
OPENSEARCH_INDEX=law_article,legal_case,legal_relation
# OPENSEARCH_API_KEY=
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=

# Query embedding model
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_DIMENSIONS=1024
# OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding provider (sentence_transformers | openai)
#EMBEDDING_PROVIDER=sentence_transformers

# sentence_transformers 사용 시 (기본값, 768 dim) -> x
#EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# LLM provider (openai_compat | gemini)
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Query Parser (법령명/조문번호 추출 LLM)
# 생략 시 GEMINI_MODEL → gemini-2.0-flash-lite 순으로 fallback
# QUERY_PARSER_MODEL=gemini-2.0-flash-lite
# QUERY_PARSER_TIMEOUT=10
# QUERY_PARSER_STRICT=false

# LLM generation
LLM_MAX_TOKENS=2048

# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse.cg-rookies.yeongmin.net
