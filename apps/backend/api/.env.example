# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
QDRANT_VECTOR_NAME_MAP=law_article=body
# QDRANT_API_KEY=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=las_legal_docs

# Embedding provider (sentence_transformers | openai)
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# OpenAI 사용 시
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_DIMENSIONS=1024

# LLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
LLM_MAX_TOKENS=4096

# PostgreSQL (Q&A history)
DATABASE_URL=postgresql://user:password@localhost:5432/las
