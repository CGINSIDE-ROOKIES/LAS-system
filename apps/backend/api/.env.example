# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
QDRANT_VECTOR_NAME_MAP=law_article=body
# QDRANT_API_KEY=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=las_legal_docs

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Embeddings (API only)
EMBEDDING_MODEL=text-embedding-3-large
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_DIMENSIONS=

# LLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
LLM_MAX_TOKENS=4096

# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# PostgreSQL (Q&A history)
DATABASE_URL=postgresql://user:password@localhost:5432/las
