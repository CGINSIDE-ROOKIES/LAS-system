# PostgreSQL
DATABASE_URL=postgresql://las:las@localhost:5432/las

# File artifacts for document review jobs.
# Leave unset to use apps/backend/api/storage/document_reviews.
# DOCUMENT_REVIEW_STORAGE_DIR=/tmp/las-document-reviews

# Logging
LOG_LEVEL=INFO

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTIONS=law_article,legal_case,legal_relation
QDRANT_VECTOR_NAME_MAP=law_article=body
# QDRANT_API_KEY=

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=law_article,legal_case,legal_relation
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
# OPENSEARCH_API_KEY=

# Query embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
OPENAI_API_KEY=
OPENAI_EMBEDDING_DIMENSIONS=1024
# OPENAI_BASE_URL=https://api.openai.com/v1

# LLM provider: gemini | openai_compat
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI-compatible chat completions when LLM_PROVIDER=openai_compat
# LLM_MODEL=gpt-4o-mini
# LLM_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=

# Optional parser-specific LLM overrides. Leave empty to use LLM_PROVIDER/GEMINI_*/LLM_* values.
DOC_PROCESSOR_LLM_PROVIDER=
DOC_PROCESSOR_LLM_MODEL=
DOC_PROCESSOR_LLM_BASE_URL=
DOC_PROCESSOR_LLM_API_KEY=
DOC_PROCESSOR_LLM_STRUCTURED_METHOD=json_mode

# Query parser
QUERY_PARSER_MODEL=gpt-4o-mini
QUERY_PARSER_TIMEOUT=10
QUERY_PARSER_STRICT=false

# Generation
LLM_MAX_TOKENS=4096

# Neo4j, required by API warmup unless warmup is changed.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
GRAPH_QUERY_MODE=template

# Langfuse optional
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
