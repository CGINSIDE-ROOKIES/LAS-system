# -----------------------------------------------------------------------------
# Frontend local env (apps/frontend)
# -----------------------------------------------------------------------------
# Public backend URL used directly by the browser. Leave empty to use same-origin /api.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Internal backend URL used by Next.js SSR and rewrites.
BACKEND_INTERNAL_URL=http://localhost:8000
# Comma-separated origins allowed to frame the frontend.
ALLOWED_FRAME_ORIGINS=
